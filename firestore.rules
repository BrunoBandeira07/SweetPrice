rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user is the owner of the document.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper function to check if the authenticated user is the existing owner of the document.
    function isExistingOwner() {
        return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Grants access to a user's ingredient data.
     * @path /databases/{database}/documents/users/{userId}/ingredients/{ingredientId}
     * @allow (create) - Authenticated user creates their own ingredient with correct userId in path.
     * @allow (get, list, update, delete) - Authenticated user reads, lists, updates, and deletes their own ingredient.
     * @deny (create) - Attempt to create an ingredient for another user.
     * @deny (get, list, update, delete) - Attempt to access another user's ingredient.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/ingredients/{ingredientId} {
      // Read Permissions
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write Permissions
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner();
      allow delete: if isExistingOwner();
    }

    /**
     * @description Grants access to a user's recipe data.
     * @path /databases/{database}/documents/users/{userId}/recipes/{recipeId}
     * @allow (create) - Authenticated user creates their own recipe with correct userId in path.
     * @allow (get, list, update, delete) - Authenticated user reads, lists, updates, and deletes their own recipe.
     * @deny (create) - Attempt to create a recipe for another user.
     * @deny (get, list, update, delete) - Attempt to access another user's recipe.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/recipes/{recipeId} {
      // Read Permissions
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write Permissions
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner();
      allow delete: if isExistingOwner();
    }

    /**
     * @description Grants access to a user's customer data.
     * @path /databases/{database}/documents/users/{userId}/customers/{customerId}
     * @allow (create) - Authenticated user creates their own customer with correct userId in path.
     * @allow (get, list, update, delete) - Authenticated user reads, lists, updates, and deletes their own customer.
     * @deny (create) - Attempt to create a customer for another user.
     * @deny (get, list, update, delete) - Attempt to access another user's customer.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/customers/{customerId} {
      // Read Permissions
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write Permissions
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner();
      allow delete: if isExistingOwner();
    }

    /**
     * @description Grants access to a user's order data.
     * @path /databases/{database}/documents/users/{userId}/orders/{orderId}
     * @allow (create) - Authenticated user creates their own order with correct userId in path.
     * @allow (get, list, update, delete) - Authenticated user reads, lists, updates, and deletes their own order.
     * @deny (create) - Attempt to create an order for another user.
     * @deny (get, list, update, delete) - Attempt to access another user's order.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/orders/{orderId} {
      // Read Permissions
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Write Permissions
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner();
      allow delete: if isExistingOwner();
    }
  }
}