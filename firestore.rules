/**
 * @fileoverview Firestore Security Rules for SweetPrice.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user has their own
 * private data store, completely isolated from other users.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, ensuring that only the authenticated
 * user can access their own data. This includes both ingredients and recipes.
 *
 * Key Security Decisions:
 * - Data is strictly segregated by user ID in the path.
 * - No public listing of user data is allowed.
 * - Denormalization is not required as the data structure inherently provides
 *   path-based authorization, avoiding the need for get() calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to a user's ingredients collection.
     * @path /users/{userId}/ingredients/{ingredientId}
     * @allow (create) - User with ID abc can create a new ingredient with the ingredient's id set to abc under /users/abc/ingredients/ghi if request.auth.uid == 'abc'.
     * @allow (get) - User abc can get the ingredient with ID ghi if request.auth.uid == 'abc'.
     * @allow (update) - User abc can update the ingredient with ID ghi if request.auth.uid == 'abc'.
     * @allow (delete) - User abc can delete the ingredient with ID ghi if request.auth.uid == 'abc'.
     * @deny (create) - User with ID def cannot create a new ingredient under /users/abc/ingredients/ghi.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/ingredients/{ingredientId} {
      // Helper function to check if the user is signed in and is the owner of the document.
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Grants access to a user's recipes collection.
     * @path /users/{userId}/recipes/{recipeId}
     * @allow (create) - User with ID abc can create a new recipe with the recipe's id set to abc under /users/abc/recipes/ghi if request.auth.uid == 'abc'.
     * @allow (get) - User abc can get the recipe with ID ghi if request.auth.uid == 'abc'.
     * @allow (update) - User abc can update the recipe with ID ghi if request.auth.uid == 'abc'.
     * @allow (delete) - User abc can delete the recipe with ID ghi if request.auth.uid == 'abc'.
     * @deny (create) - User with ID def cannot create a new recipe under /users/abc/recipes/ghi.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/recipes/{recipeId} {
      // Helper function to check if the user is signed in and is the owner of the document.
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}