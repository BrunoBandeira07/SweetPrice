/**
 * @file Firebase Security Rules for SweetPrice Firestore database.
 *
 * Core Philosophy:
 * This ruleset allows open read access (get, list) to all data, reflecting the application's intention to allow any user to view all information. Write access (create, update, delete) is restricted to authenticated users.
 *
 * Data Structure:
 * The database consists of four top-level collections: /ingredients/{ingredientId}, /recipes/{recipeId}, /ingredientQuantities/{ingredientQuantityId}, and /profitMargins/{profitMarginId}. There are no user-specific subcollections.
 *
 * Key Security Decisions:
 * - Unauthenticated users can read all data.
 * - Only authenticated users can create, update, or delete data.
 * - No data validation is performed beyond requiring authentication for write operations, prioritizing rapid prototyping.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 *  Not applicable. This version assumes global access.
 *
 * Structural Segregation:
 *  Not applicable. All collections are top-level and publicly readable.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read ingredients, but only authenticated users can create, update, or delete them.
     * @path /ingredients/{ingredientId}
     * @allow (get, list): Any user can read ingredient data.
     * @allow (create): An authenticated user can create a new ingredient.
     * @allow (update): An authenticated user can update an existing ingredient.
     * @allow (delete): An authenticated user can delete an existing ingredient.
     * @deny (create): An unauthenticated user cannot create an ingredient.
     * @deny (update): An unauthenticated user cannot update an ingredient.
     * @deny (delete): An unauthenticated user cannot delete an ingredient.
     * @principle Allows public read access, but only authenticated users can modify data.
     */
    match /ingredients/{ingredientId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows anyone to read recipes, but only authenticated users can create, update, or delete them.
     * @path /recipes/{recipeId}
     * @allow (get, list): Any user can read recipe data.
     * @allow (create): An authenticated user can create a new recipe.
     * @allow (update): An authenticated user can update an existing recipe.
     * @allow (delete): An authenticated user can delete an existing recipe.
     * @deny (create): An unauthenticated user cannot create a recipe.
     * @deny (update): An unauthenticated user cannot update a recipe.
     * @deny (delete): An unauthenticated user cannot delete an recipe.
     * @principle Allows public read access, but only authenticated users can modify data.
     */
    match /recipes/{recipeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows anyone to read ingredient quantities, but only authenticated users can create, update, or delete them.
     * @path /ingredientQuantities/{ingredientQuantityId}
     * @allow (get, list): Any user can read ingredient quantity data.
     * @allow (create): An authenticated user can create a new ingredient quantity.
     * @allow (update): An authenticated user can update an existing ingredient quantity.
     * @allow (delete): An authenticated user can delete an existing ingredient quantity.
     * @deny (create): An unauthenticated user cannot create an ingredient quantity.
     * @deny (update): An unauthenticated user cannot update an ingredient quantity.
     * @deny (delete): An unauthenticated user cannot delete an ingredient quantity.
     * @principle Allows public read access, but only authenticated users can modify data.
     */
    match /ingredientQuantities/{ingredientQuantityId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows anyone to read profit margins, but only authenticated users can create, update, or delete them.
     * @path /profitMargins/{profitMarginId}
     * @allow (get, list): Any user can read profit margin data.
     * @allow (create): An authenticated user can create a new profit margin.
     * @allow (update): An authenticated user can update an existing profit margin.
     * @allow (delete): An authenticated user can delete an existing profit margin.
     * @deny (create): An unauthenticated user cannot create a profit margin.
     * @deny (update): An unauthenticated user cannot update a profit margin.
     * @deny (delete): An unauthenticated user cannot delete an profit margin.
     * @principle Allows public read access, but only authenticated users can modify data.
     */
    match /profitMargins/{profitMarginId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Users cannot be listed.
    match /users/{userId} {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}