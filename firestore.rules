/**
 * @file Firebase Security Rules for SweetPrice application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, where each user has exclusive access to their own data stored under their unique user ID.
 *
 * Data Structure:
 * All data (ingredients and recipes) is nested under /users/{userId}, ensuring clear ownership and simplified security rules.
 *
 * Key Security Decisions:
 * - Users can only access their own ingredients and recipes.
 * - Listing other user's data is disallowed.
 * - Data validation is relaxed in this prototyping phase, focusing on ownership and relational integrity.
 *
 * Denormalization for Authorization:
 * The data model uses path-based ownership: the user ID is embedded in the path, eliminating the need for additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user-specific ingredient documents.
     * @path /users/{userId}/ingredients/{ingredientId}
     * @allow (get, list) Authenticated user accessing their own ingredient data.
     *   Request: { auth: { uid: 'user123' }, method: 'get', path: '/databases/(default)/documents/users/user123/ingredients/ingredient456' }
     * @allow (create) Authenticated user creating an ingredient under their user ID.
     *   Request: { auth: { uid: 'user123' }, method: 'create', path: '/databases/(default)/documents/users/user123/ingredients/newIngredient' }
     * @allow (update, delete) Authenticated user updating or deleting their own ingredient data.
     *   Request: { auth: { uid: 'user123' }, method: 'update', path: '/databases/(default)/documents/users/user123/ingredients/ingredient456' }
     * @deny (get, list) Authenticated user attempting to access another user's ingredient data.
     *   Request: { auth: { uid: 'user456' }, method: 'get', path: '/databases/(default)/documents/users/user123/ingredients/ingredient456' }
     * @deny (create, update, delete) Unauthenticated user attempting to modify any ingredient data.
     *   Request: { auth: null, method: 'create', path: '/databases/(default)/documents/users/user123/ingredients/newIngredient' }
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/ingredients/{ingredientId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to user-specific recipe documents.
     * @path /users/{userId}/recipes/{recipeId}
     * @allow (get, list) Authenticated user accessing their own recipe data.
     *   Request: { auth: { uid: 'user123' }, method: 'get', path: '/databases/(default)/documents/users/user123/recipes/recipe456' }
     * @allow (create) Authenticated user creating a recipe under their user ID.
     *   Request: { auth: { uid: 'user123' }, method: 'create', path: '/databases/(default)/documents/users/user123/recipes/newRecipe' }
     * @allow (update, delete) Authenticated user updating or deleting their own recipe data.
     *   Request: { auth: { uid: 'user123' }, method: 'update', path: '/databases/(default)/documents/users/user123/recipes/recipe456' }
     * @deny (get, list) Authenticated user attempting to access another user's recipe data.
     *   Request: { auth: { uid: 'user456' }, method: 'get', path: '/databases/(default)/documents/users/user123/recipes/recipe456' }
     * @deny (create, update, delete) Unauthenticated user attempting to modify any recipe data.
     *   Request: { auth: null, method: 'create', path: '/databases/(default)/documents/users/user123/recipes/newRecipe' }
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/recipes/{recipeId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
    
    /**
     * @description Controls access to user-specific settings documents.
     * @path /users/{userId}/settings/{settingId}
     */
    match /users/{userId}/settings/{settingId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}