
{
  "entities": {
    "Ingredient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ingredient",
      "type": "object",
      "description": "Represents an ingredient used in recipes, including cost and supplier information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ingredient."
        },
        "userId": {
            "type": "string",
            "description": "The ID of the user who owns this ingredient."
        },
        "name": {
          "type": "string",
          "description": "Name of the ingredient."
        },
        "cost": {
          "type": "number",
          "description": "Purchase cost of the ingredient per unit."
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement for the ingredient (e.g., kg, g, ml, piece)."
        },
        "supplier": {
          "type": "string",
          "description": "Name of the supplier for the ingredient."
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "cost",
        "unit"
      ]
    },
    "Recipe": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Recipe",
      "type": "object",
      "description": "Represents a recipe, combining ingredients and defining profit margins to calculate selling price.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the recipe."
        },
        "userId": {
            "type": "string",
            "description": "The ID of the user who owns this recipe."
        },
        "name": {
          "type": "string",
          "description": "Name of the recipe."
        },
        "items": {
          "type": "array",
          "description": "List of items in the recipe, including ingredients, labor, and equipment usage.",
          "items": {
            "type": "object"
          }
        },
        "totalCost": {
            "type": "number",
            "description": "Total calculated cost of all items in the recipe."
        },
        "suggestedPrice": {
          "type": "number",
          "description": "Automatically calculated selling price based on total cost and profit margin."
        },
        "margin": {
          "type": "number",
          "description": "The value of the profit margin."
        },
        "marginType": {
          "type": "string",
          "enum": ["percentage", "fixed"],
          "description": "The type of profit margin (percentage or fixed value)."
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "items",
        "totalCost",
        "suggestedPrice"
      ]
    },
    "Customer": {
        "title": "Customer",
        "type": "object",
        "description": "Represents a customer.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "cpf": { "type": "string" },
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "instagram": { "type": "string" },
            "lastOrderDate": { "type": "string", "format": "date-time" },
            "crmSuggestion": { "type": "string" }
        },
        "required": ["id", "userId", "name"]
    },
    "Order": {
        "title": "Order",
        "type": "object",
        "description": "Represents a customer order.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "customerName": { "type": "string" },
            "deliveryDate": { "type": "string", "format": "date-time" },
            "items": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "recipe": { "$ref": "#/entities/Recipe" },
                        "quantity": { "type": "number" }
                    },
                    "required": ["recipe", "quantity"]
                }
            },
            "total": { "type": "number" },
            "deliveryStatus": { "type": "string", "enum": ["pending", "delivered", "cancelled"] },
            "productionStatus": { "type": "string", "enum": ["to_do", "buying_supplies", "producing", "finishing", "ready_for_delivery"] }
        },
        "required": ["id", "userId", "customerName", "deliveryDate", "items", "total", "deliveryStatus", "productionStatus"]
    },
    "Campaign": {
        "title": "Campaign",
        "type": "object",
        "description": "Represents a marketing campaign.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "status": { "type": "string", "enum": ["planning", "in_progress", "completed", "archived"] },
            "startDate": { "type": "string", "format": "date-time" },
            "endDate": { "type": "string", "format": "date-time" },
            "tasks": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": { "type": "string" },
                        "text": { "type": "string" },
                        "completed": { "type": "boolean" }
                    },
                    "required": ["id", "text", "completed"]
                }
            }
        },
        "required": ["id", "userId", "name", "status", "startDate", "endDate", "tasks"]
    },
    "Settings": {
        "title": "Settings",
        "type": "object",
        "description": "User-specific application settings.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "monthlyGoal": { "type": "number" }
        },
        "required": ["id", "userId"]
    },
    "Costs": {
        "title": "Costs",
        "type": "object",
        "description": "User-specific cost settings.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "kwhPrice": { "type": "number" },
            "gasCylinderSize": { "type": "string", "enum": ["8", "10", "13"] },
            "gasCylinderPrice": { "type": "number" },
            "proLabore": { "type": "number" },
            "creditCardFee": { "type": "number" },
            "indirectCostsRate": { "type": "number" },
            "taxRate": { "type": "number" },
            "microwavePower": { "type": "number" },
            "blenderPower": { "type": "number" },
            "mixerPower": { "type": "number" },
            "electricOvenPower": { "type": "number" },
            "brigadeiroPanPower": { "type": "number" },
            "fryerPower": { "type": "number" },
            "gasFryerFlow": { "type": "number" },
            "stoveBurnerFlow": { "type": "number" },
            "gasOvenFlow": { "type": "number" },
            "customExpenses": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "value": { "type": "number" },
                        "unit": { "type": "string" }
                    },
                    "required": ["name", "value", "unit"]
                }
            }
        },
        "required": ["id", "userId"]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/ingredients/{ingredientId}": {
        "schema": { "$ref": "#/entities/Ingredient" },
        "description": "Stores all ingredients for all users."
    },
    "/recipes/{recipeId}": {
        "schema": { "$ref": "#/entities/Recipe" },
        "description": "Stores all recipes for all users."
    },
    "/customers/{customerId}": {
        "schema": { "$ref": "#/entities/Customer" },
        "description": "Stores all customers for all users."
    },
    "/orders/{orderId}": {
        "schema": { "$ref": "#/entities/Order" },
        "description": "Stores all orders for all users."
    },
    "/campaigns/{campaignId}": {
        "schema": { "$ref": "#/entities/Campaign" },
        "description": "Stores all campaigns for all users."
    },
    "/settings/{userId}": {
        "schema": { "$ref": "#/entities/Settings" },
        "description": "Stores general settings for each user. Document ID is the user ID."
    },
    "/costs/{userId}": {
        "schema": { "$ref": "#/entities/Costs" },
        "description": "Stores cost settings for each user. Document ID is the user ID."
    }
  }
}
    
