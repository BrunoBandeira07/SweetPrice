{
  "entities": {
    "Ingredient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ingredient",
      "type": "object",
      "description": "Represents an ingredient used in recipes, including cost, quantity, and supplier information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cost": { "type": "number" },
        "packageSize": { "type": "number" },
        "unit": { "type": "string", "enum": ["g", "kg", "ml", "l", "un"] },
        "supplier": { "type": "string" },
        "category": { "type": "string" },
        "unitCost": { "type": "number" },
        "lossFactor": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "expirationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "cost", "packageSize", "unit"]
    },
    "Recipe": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Recipe",
      "type": "object",
      "description": "Represents a recipe composed of multiple ingredients and their quantities.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/RecipeItem" }
        },
        "totalCost": { "type": "number" },
        "suggestedPrice": { "type": "number" }
      },
      "required": ["id", "name", "items"]
    },
    "RecipeItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RecipeItem",
      "description": "Represents a single item within a recipe, which could be an ingredient, labor, or equipment usage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["ingredient", "labor", "equipment"] },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "cost": { "type": "number" },
        "ingredient": {
          "description": "Full ingredient object, denormalized for direct access.",
          "$ref": "#/entities/Ingredient"
        },
        "equipmentKey": { "type": "string" }
      },
      "required": ["id", "type", "name", "quantity", "unit", "cost"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "description": "Represents a customer of the confectionery business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "lastOrderDate": { "type": "string", "format": "date-time" },
        "crmSuggestion": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "recipe": { "$ref": "#/entities/Recipe" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "deliveryStatus": { "type": "string", "enum": ["pending", "delivered", "cancelled"] },
        "productionStatus": { "type": "string", "enum": ["to_do", "buying_supplies", "producing", "finishing", "ready_for_delivery"] }
      },
      "required": ["id", "customerName", "deliveryDate", "items", "total", "deliveryStatus", "productionStatus"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Represents a marketing campaign with tasks and a schedule.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "in_progress", "completed", "archived"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/entities/CampaignTask" }
        }
      },
      "required": ["id", "name", "status", "startDate", "endDate"]
    },
    "CampaignTask": {
      "title": "Campaign Task",
      "description": "A single task within a marketing campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "text", "completed"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "Stores general user-specific settings, including costs and goals.",
      "type": "object",
      "properties": {
        "monthlyGoal": { "type": "number" },
        "kwhPrice": { "type": "number" },
        "gasCylinderSize": { "type": "string", "enum": ["8", "10", "13"] },
        "gasCylinderPrice": { "type": "number" },
        "proLabore": { "type": "number" },
        "creditCardFee": { "type": "number" },
        "indirectCostsRate": { "type": "number" },
        "taxRate": { "type": "number" },
        "microwavePower": { "type": "number" },
        "blenderPower": { "type": "number" },
        "mixerPower": { "type": "number" },
        "electricOvenPower": { "type": "number" },
        "brigadeiroPanPower": { "type": "number" },
        "fryerPower": { "type": "number" },
        "gasFryerFlow": { "type": "number" },
        "stoveBurnerFlow": { "type": "number" },
        "gasOvenFlow": { "type": "number" },
        "customExpenses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "number" },
              "unit": { "type": "string" }
            },
            "required": ["name", "value", "unit"]
          }
        }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}/ingredients/{ingredientId}": {
      "schema": { "$ref": "#/entities/Ingredient" },
      "description": "Stores all ingredient data for a specific user."
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": { "$ref": "#/entities/Recipe" },
      "description": "Stores all recipe data for a specific user."
    },
    "/users/{userId}/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Stores all customer data for a specific user."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores all order data for a specific user."
    },
    "/users/{userId}/campaigns/{campaignId}": {
      "schema": { "$ref": "#/entities/Campaign" },
      "description": "Stores all campaign data for a specific user."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": { "$ref": "#/entities/UserSettings" },
      "description": "Stores user-specific settings documents, like 'costs' or 'general'."
    }
  }
}
